@page "/virtualmachines"
@using Toolbox.Data.Services
@using Toolbox.Data.Models
@using Toolbox.Data.Models.Interfaces
@using Toolbox.Components.Dialogs
@inject VmwareService VmwareService
@inject StagingSystemSyncService SyncService
@inject ISettingsService SettingsService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<div class="d-flex flex-column h-100 gap-2 p-3">

    <!-- Toolbar -->
    <div class="d-flex align-items-center gap-2 flex-wrap">
        @if (VmwareService.IsConnected)
        {
            <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.Cloud" Size="Size.Small">
                Verbunden
            </MudChip>
            <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       OnClick="RefreshAsync"
                       Disabled="_loading">
                Aktualisieren
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.CloudOff"
                       Variant="Variant.Text"
                       Color="Color.Default"
                       OnClick="DisconnectAsync"
                       Disabled="_loading">
                Trennen
            </MudButton>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudTooltip Text="Lädt IP-Adresse, Hostname und Betriebssystem nach (eine Anfrage pro VM)">
                <MudCheckBox T="bool" @bind-Value="_autoLoadDetails" Color="Color.Primary" Size="Size.Small">
                    Details laden
                </MudCheckBox>
            </MudTooltip>
            <MudDivider Vertical="true" FlexItem="true" />
            <MudButton StartIcon="@Icons.Material.Filled.Sync"
                       Variant="Variant.Text"
                       Color="Color.Secondary"
                       OnClick="SyncCustomerMappingsAsync"
                       Disabled="_syncing">
                VM-Kunden sync
            </MudButton>
            @if (_syncing)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@_syncMessage</MudText>
            }
        }
        else
        {
            <MudChip T="string" Color="Color.Default" Icon="@Icons.Material.Filled.CloudOff" Size="Size.Small">
                Nicht verbunden
            </MudChip>
            <MudButton StartIcon="@Icons.Material.Filled.CloudSync"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="ConnectAsync"
                       Disabled="_loading">
                Verbinden
            </MudButton>
        }

        @if (_loading)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary">@_loadingMessage</MudText>
        }
    </div>

    @if (!string.IsNullOrEmpty(_lastError))
    {
        <MudAlert Severity="Severity.Error" Dense="true" ShowCloseIcon="true" CloseIconClicked="() => _lastError = string.Empty">
            @_lastError
        </MudAlert>
    }

    @if (!VmwareService.IsConnected && !_loading)
    {
        <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1 gap-3 text-center">
            <MudIcon Icon="@Icons.Material.Filled.Cloud" Style="font-size: 96px; opacity: 0.2;" />
            <MudText Typo="Typo.h5" Class="mud-text-secondary">Nicht mit vCenter verbunden</MudText>
            @if (string.IsNullOrWhiteSpace(SettingsService.Settings?.VCenterUrl))
            {
                <MudText Class="mud-text-secondary">
                    Bitte vCenter-Zugangsdaten in den Einstellungen konfigurieren.
                </MudText>
                <MudButton Variant="Variant.Outlined"
                           Href="settings"
                           StartIcon="@Icons.Material.Filled.Settings">
                    Einstellungen öffnen
                </MudButton>
            }
            else
            {
                <MudButton StartIcon="@Icons.Material.Filled.CloudSync"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="ConnectAsync">
                    Verbinden
                </MudButton>
            }
        </div>
    }
    else if (VmwareService.IsConnected)
    {
        <!-- Filter bar -->
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <MudTextField T="string"
                          @bind-Value="_searchText"
                          Label="Suche"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true"
                          Style="max-width: 350px;" />
            <MudSelect T="string"
                       @bind-Value="_powerFilter"
                       Label="Status"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="min-width: 170px">
                <MudSelectItem Value="@("ALL")">Alle</MudSelectItem>
                <MudSelectItem Value="@("POWERED_ON")">Eingeschaltet</MudSelectItem>
                <MudSelectItem Value="@("POWERED_OFF")">Ausgeschaltet</MudSelectItem>
                <MudSelectItem Value="@("SUSPENDED")">Suspendiert</MudSelectItem>
            </MudSelect>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @FilteredVms.Count() von @_vms.Count VM(s)
            </MudText>
        </div>

        <!-- VM Table -->
        <MudDataGrid T="VmwareVm"
                     Items="FilteredVms"
                     Dense="true"
                     Hover="true"
                     Striped="true"
                     SortMode="SortMode.Single"
                     Filterable="false"
                     FixedHeader="true"
                     Height="calc(100vh - 280px)">
            <Columns>
                <PropertyColumn Property="x => x.Name" Title="Name" />

                <TemplateColumn Title="Kunde" SortBy="x => GetCustomerName(x.Name)">
                    <CellTemplate>
                        @{
                            var customer = GetCustomerName(context.Item.Name);
                        }
                        @if (!string.IsNullOrEmpty(customer))
                        {
                            <MudText Typo="Typo.body2">@customer</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-disabled">–</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Status" SortBy="x => x.PowerState">
                    <CellTemplate>
                        @{
                            var (color, label, icon) = GetPowerDisplay(context.Item.PowerState);
                        }
                        <MudChip T="string" Color="color" Size="Size.Small" Icon="@icon" Class="ma-0">
                            @label
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="CPU" SortBy="x => x.CpuCount">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">
                            @(context.Item.CpuCount > 0 ? context.Item.CpuCount.ToString() : "–")
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="RAM" SortBy="x => x.MemoryMib">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">@FormatRam(context.Item.MemoryMib)</MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="IP-Adresse" SortBy="x => x.IpAddress">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.IpAddress))
                        {
                            <MudText Typo="Typo.body2">@context.Item.IpAddress</MudText>
                        }
                        else if (!context.Item.DetailsLoaded && _autoLoadDetails)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-disabled">–</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Hostname" SortBy="x => x.HostName">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">
                            @(string.IsNullOrEmpty(context.Item.HostName) ? "–" : context.Item.HostName)
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Betriebssystem" SortBy="x => x.GuestOs">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">
                            @(string.IsNullOrEmpty(context.Item.GuestOs) ? "–" : context.Item.GuestOs)
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Aktionen" CellClass="pa-0">
                    <CellTemplate>
                        @{
                            var vm = context.Item;
                            var on = vm.PowerState == "POWERED_ON";
                            var off = vm.PowerState == "POWERED_OFF";
                            var sus = vm.PowerState == "SUSPENDED";
                            var busy = _busyVms.Contains(vm.Id);
                        }
                        <div class="d-flex align-items-center">
                            @if (off || sus)
                            {
                                <MudTooltip Text="Einschalten">
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@Icons.Material.Filled.PlayArrow"
                                                   Color="Color.Success"
                                                   OnClick="() => PowerOnVmAsync(vm)"
                                                   Disabled="busy" />
                                </MudTooltip>
                            }
                            @if (on)
                            {
                                <MudTooltip Text="Herunterfahren (Gast-Betriebssystem)">
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@Icons.Material.Filled.PowerSettingsNew"
                                                   Color="Color.Warning"
                                                   OnClick="() => ShutdownGuestVmAsync(vm)"
                                                   Disabled="busy" />
                                </MudTooltip>
                                <MudTooltip Text="Ausschalten (erzwingen)">
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@Icons.Material.Filled.Stop"
                                                   Color="Color.Error"
                                                   OnClick="() => PowerOffVmAsync(vm)"
                                                   Disabled="busy" />
                                </MudTooltip>
                                <MudTooltip Text="Neustart (Gast-Betriebssystem)">
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@Icons.Material.Filled.RestartAlt"
                                                   Color="Color.Info"
                                                   OnClick="() => RebootGuestVmAsync(vm)"
                                                   Disabled="busy" />
                                </MudTooltip>
                                <MudTooltip Text="Zurücksetzen (erzwingen)">
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@Icons.Material.Filled.Replay"
                                                   Color="Color.Warning"
                                                   OnClick="() => ResetVmAsync(vm)"
                                                   Disabled="busy" />
                                </MudTooltip>
                                <MudTooltip Text="Suspendieren">
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@Icons.Material.Filled.Pause"
                                                   Color="Color.Default"
                                                   OnClick="() => SuspendVmAsync(vm)"
                                                   Disabled="busy" />
                                </MudTooltip>
                            }
                            <MudTooltip Text="Snapshots verwalten">
                                <MudIconButton Size="Size.Small"
                                               Icon="@Icons.Material.Filled.PhotoCamera"
                                               Color="Color.Primary"
                                               OnClick="() => OpenSnapshotsAsync(vm)" />
                            </MudTooltip>
                            @if (busy)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ml-1" />
                            }
                        </div>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <NoRecordsContent>
                <MudText Class="mud-text-secondary pa-4">Keine VMs gefunden.</MudText>
            </NoRecordsContent>
        </MudDataGrid>
    }
</div>

@code {
    private List<VmwareVm> _vms = new();
    private List<VmCustomerMapping> _customerMappings = new();
    private readonly HashSet<string> _busyVms = new();
    private bool _loading;
    private string _loadingMessage = "";
    private string _lastError = "";
    private string _searchText = "";
    private string _powerFilter = "ALL";
    private bool _autoLoadDetails = true;
    private bool _initialized;
    private bool _syncing;
    private string _syncMessage = "";

    private IEnumerable<VmwareVm> FilteredVms => _vms
        .Where(v =>
            string.IsNullOrEmpty(_searchText) ||
            v.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            (v.IpAddress ?? "").Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            (v.HostName ?? "").Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            (v.GuestOs ?? "").Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .Where(v => _powerFilter == "ALL" || v.PowerState == _powerFilter);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized) return;
        _initialized = true;

        _customerMappings = await SyncService.GetMappingsAsync();

        if (!VmwareService.IsConnected && !string.IsNullOrWhiteSpace(SettingsService.Settings?.VCenterUrl))
            await ConnectAsync();
    }

    private string? GetCustomerName(string vmName) =>
        _customerMappings.FirstOrDefault(m =>
            string.Equals(m.VmName, vmName, StringComparison.OrdinalIgnoreCase))?.CustomerName;

    private async Task SyncCustomerMappingsAsync()
    {
        _syncing = true;
        _syncMessage = "Starte Sync...";
        StateHasChanged();

        try
        {
            var progress = new Progress<string>(msg =>
            {
                _syncMessage = msg;
                InvokeAsync(StateHasChanged);
            });

            var result = await SyncService.SyncAsync(progress);

            if (result.Errors.Any())
                Snackbar.Add($"Sync abgeschlossen mit Fehlern: {string.Join(", ", result.Errors)}", Severity.Warning);
            else
                Snackbar.Add($"Sync abgeschlossen: {result.Added} neu, {result.Updated} aktualisiert ({result.ProjectsScanned} Projekte gescannt).", Severity.Success);

            _customerMappings = await SyncService.GetMappingsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Sync fehlgeschlagen: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncing = false;
            _syncMessage = "";
            StateHasChanged();
        }
    }

    private async Task ConnectAsync()
    {
        _loading = true;
        _loadingMessage = "Verbinde mit vCenter...";
        _lastError = "";
        StateHasChanged();

        var ok = await VmwareService.ConnectAsync();
        if (ok)
            await LoadVmsAsync();
        else
            _lastError = VmwareService.LastError ?? "Verbindung fehlgeschlagen.";

        _loading = false;
        StateHasChanged();
    }

    private async Task LoadVmsAsync()
    {
        try
        {
            _loadingMessage = "Lade VM-Liste...";
            StateHasChanged();
            _vms = await VmwareService.GetVmsAsync();

            if (_autoLoadDetails && _vms.Any())
            {
                _loadingMessage = "Lade VM-Details...";
                StateHasChanged();

                var semaphore = new SemaphoreSlim(10);
                var tasks = _vms.Select(async vm =>
                {
                    await semaphore.WaitAsync();
                    try
                    {
                        await VmwareService.LoadVmDetailsAsync(vm);
                        await InvokeAsync(StateHasChanged);
                    }
                    finally
                    {
                        semaphore.Release();
                    }
                }).ToList();

                await Task.WhenAll(tasks);
            }
        }
        catch (Exception ex)
        {
            _lastError = ex.Message;
        }
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        _lastError = "";
        await LoadVmsAsync();
        _loading = false;
        StateHasChanged();
    }

    private async Task DisconnectAsync()
    {
        await VmwareService.DisconnectAsync();
        _vms.Clear();
        StateHasChanged();
    }

    private Task PowerOnVmAsync(VmwareVm vm) =>
        ExecuteVmActionAsync(vm, () => VmwareService.PowerOnAsync(vm.Id), "Einschalten");
    private Task PowerOffVmAsync(VmwareVm vm) =>
        ExecuteVmActionAsync(vm, () => VmwareService.PowerOffAsync(vm.Id), "Ausschalten");
    private Task ShutdownGuestVmAsync(VmwareVm vm) =>
        ExecuteVmActionAsync(vm, () => VmwareService.ShutdownGuestAsync(vm.Id), "Herunterfahren");
    private Task RebootGuestVmAsync(VmwareVm vm) =>
        ExecuteVmActionAsync(vm, () => VmwareService.RebootGuestAsync(vm.Id), "Neustart");
    private Task ResetVmAsync(VmwareVm vm) =>
        ExecuteVmActionAsync(vm, () => VmwareService.ResetAsync(vm.Id), "Zurücksetzen");
    private Task SuspendVmAsync(VmwareVm vm) =>
        ExecuteVmActionAsync(vm, () => VmwareService.SuspendAsync(vm.Id), "Suspendieren");

    private async Task ExecuteVmActionAsync(VmwareVm vm, Func<Task<bool>> action, string actionName)
    {
        _busyVms.Add(vm.Id);
        StateHasChanged();
        try
        {
            var ok = await action();
            if (ok)
            {
                Snackbar.Add($"'{vm.Name}': {actionName} wird ausgeführt.", Severity.Success);
                await Task.Delay(2500);
                await LoadVmsAsync();
            }
            else
            {
                Snackbar.Add(VmwareService.LastError ?? $"Fehler beim {actionName}.", Severity.Error);
            }
        }
        finally
        {
            _busyVms.Remove(vm.Id);
            StateHasChanged();
        }
    }

    private async Task OpenSnapshotsAsync(VmwareVm vm)
    {
        var parameters = new DialogParameters
        {
            ["VmId"] = vm.Id,
            ["VmName"] = vm.Name
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<VmSnapshotDialog>($"Snapshots – {vm.Name}", parameters, options);
    }

    private static (Color color, string label, string icon) GetPowerDisplay(string powerState) =>
        powerState switch
        {
            "POWERED_ON" => (Color.Success, "Eingeschaltet", Icons.Material.Filled.Circle),
            "POWERED_OFF" => (Color.Default, "Ausgeschaltet", Icons.Material.Outlined.Circle),
            "SUSPENDED" => (Color.Warning, "Suspendiert", Icons.Material.Filled.PauseCircleFilled),
            _ => (Color.Default, powerState, Icons.Material.Outlined.Circle)
        };

    private static string FormatRam(int mib) =>
        mib <= 0 ? "–" : mib >= 1024 ? $"{mib / 1024} GB" : $"{mib} MB";
}
