@using Toolbox.Data.Common
@using Toolbox.Data.Models
@using Toolbox.Services
@inject SettingsService SettingsService
@inject EventLogService EventLogService
@inject NotificationService NotificationService

<div class="row g-0 pl-4 flex-column">
    <div class="col-12 mt-3 d-flex gap-1 align-items-center justify-content-center">
        <MudText Class="fw-bold" Typo="Typo.body1">Ereignisanzeige</MudText>
        <MudDivider Class="w-auto"></MudDivider>
    </div>
    <div class="col-12 d-flex flex-column gap-2">
        <div class="settings-field-with-help">
            <MudSelect T="string"
                       MultiSelection="true"
                       MultiSelectionTextFunc="@(new Func<List<string>, string>(GetLogSelectionText))"
                       SelectedValues="_selectedLogNames"
                       SelectedValuesChanged="@(names => SelectedLogNamesChanged(names))"
                       FullWidth="true"
                       Disabled="@(!_availableLogNames.Any())"
                       Label="Log-Namen (Ereignisanzeige)"
                       Class="pl-4 settings-field-grow">
                @foreach (var name in _availableLogNames)
                {
                    <MudSelectItem Value="@name">@name</MudSelectItem>
                }
            </MudSelect>
            <SettingsHelp PropertyName="@nameof(ToolboxSettings.LogName)" />
        </div>
        @if (!_availableLogNames.Any())
        {
            <MudText Typo="Typo.caption" Class="text-secondary pl-4">Keine Ereignisanzeige-Logs gefunden.</MudText>
        }
        <div class="settings-field-with-help">
            <MudSelect ValueChanged="(int i) => SettingsService.SaveSettingChanges(x => x = ChangeAutoLoadSettings(x, i) , NotificationService)" T="int" Value="Setting.AutoRefreshSeconds" FullWidth="true" Label="Zeitlicher Abstand zwischen automatischem Neuladen der Logs" Class="pl-4 settings-field-grow">
                @foreach (var reloadTime in ReloadTime.ReloadTimes)
                {
                    <MudSelectItem Value="@(Int32.Parse(reloadTime.Value.TotalSeconds.ToString()))">@reloadTime.Key</MudSelectItem>
                }
            </MudSelect>
            <SettingsHelp PropertyName="@nameof(ToolboxSettings.AutoRefreshSeconds)" />
        </div>
        <MudCheckBox Class="p-0" ValueChanged="(bool i) => SettingsService.SaveSettingChanges(x => x.BundleLogs = i, NotificationService)" Value="Setting.BundleLogs" T="bool" Color="Color.Primary">
            Gleiche Logs bündeln
            <SettingsHelp PropertyName="@nameof(ToolboxSettings.BundleLogs)" />
        </MudCheckBox>
    </div>
</div>

@code {
    private ToolboxSettings Setting => SettingsService.Settings;
    private readonly List<string> _availableLogNames = new();
    private HashSet<string> _selectedLogNames = new(StringComparer.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        LoadAvailableLogNames();
        LoadSelectedLogNames();
    }

    private void LoadAvailableLogNames()
    {
        _availableLogNames.Clear();
        _availableLogNames.AddRange(EventLogService.GetLogNames());
        _availableLogNames.Sort(StringComparer.OrdinalIgnoreCase);
    }

    private void LoadSelectedLogNames()
    {
        _selectedLogNames = new HashSet<string>(Setting.GetLogNames(), StringComparer.OrdinalIgnoreCase);
        foreach (var name in _selectedLogNames)
        {
            if (!_availableLogNames.Exists(n => string.Equals(n, name, StringComparison.OrdinalIgnoreCase)))
            {
                _availableLogNames.Add(name);
            }
        }
        _availableLogNames.Sort(StringComparer.OrdinalIgnoreCase);
    }

    private void SelectedLogNamesChanged(IEnumerable<string> names)
    {
        _selectedLogNames = new HashSet<string>(names, StringComparer.OrdinalIgnoreCase);
        SettingsService.SaveSettingChanges(x => x.SetLogNames(_selectedLogNames), NotificationService);
    }

    private string GetLogSelectionText(List<string> selectedValues)
    {
        if (_availableLogNames.Count == 0)
        {
            return "Keine Logs verfügbar";
        }

        if (selectedValues.Count == 0)
        {
            return "Keine Logs ausgewählt";
        }

        if (selectedValues.Count == _availableLogNames.Count)
        {
            return "Alle Logs";
        }

        return string.Join(", ", selectedValues);
    }

    private ToolboxSettings ChangeAutoLoadSettings(ToolboxSettings setting, int newValue)
    {
        setting.AutoRefreshSeconds = newValue;
        setting.AutoRefreshEnabled = newValue > 0;
        return setting;
    }
}
