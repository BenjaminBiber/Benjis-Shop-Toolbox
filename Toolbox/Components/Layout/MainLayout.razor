@using MudBlazor
@using Toolbox.Themes
@using Toolbox.Components.Layout.TopBar
@using Toolbox.Components.Dialogs
@using Toolbox.Services
@inherits LayoutComponentBase
@implements IDisposable
@inject UiThemeState ThemeState
@inject IDialogService DialogService
@inject ChangelogService ChangelogService

<MudThemeProvider Theme="@CurrentTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="@LayoutClass">
    <TopBar />
    <MudMainContent Class="main-content">
        <div class="content">
            @Body
        </div>
    </MudMainContent>
    
    
</MudLayout>

@code {
    private MudTheme CurrentTheme => ThemeState.IsWin95Mode ? Windows95Theme.Theme : ModernTheme.Yetitheme;
    private string LayoutClass => ThemeState.IsWin95Mode ? "win95-mode" : string.Empty;
    private bool _changelogChecked;

    protected override void OnInitialized()
    {
        ThemeState.StateChanged += OnThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _changelogChecked)
        {
            return;
        }

        _changelogChecked = true;

        try
        {
            var report = await ChangelogService.TryBuildPendingReportAsync(ChangelogService.GetCurrentVersion());
            if (report == null)
            {
                return;
            }

            var parameters = new DialogParameters
            {
                { nameof(ChangelogDialog.Report), report }
            };
            var options = new DialogOptions
            {
                CloseButton = true,
                FullWidth = true,
                MaxWidth = MaxWidth.Large
            };

            var dialog = await DialogService.ShowAsync<ChangelogDialog>("Changelog", parameters, options);
            await dialog.Result;
            ChangelogService.MarkPendingAsShown();
        }
        catch
        {
            // ignore
        }
    }

    private void OnThemeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeState.StateChanged -= OnThemeChanged;
    }
}
