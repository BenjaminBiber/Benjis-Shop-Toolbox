@page "/SQLDialog"
@using Blazor.AceEditorJs

<AceJsEditor Class="sql-dialog-editor" @bind-Value="@SqlText" Options="_opt"></AceJsEditor>

@code {
    [Parameter] public string SqlText { get; set; } = "";
    readonly AceEditorOptions _opt = new() { IsReadOnly = false, Language = AceLanguage.sqlserver, Theme = AceTheme.sqlserver };
}
