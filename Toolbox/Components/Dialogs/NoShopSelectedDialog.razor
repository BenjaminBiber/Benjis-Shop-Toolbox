@using Microsoft.AspNetCore.Components

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-2">Kein Shopsystem ausgewählt</MudText>
        <MudAlert Icon="@Icons.Material.Filled.Warning"
                  Variant="Variant.Filled"
                  Severity="Severity.Warning"
                  Class="mb-3">
            Es ist aktuell kein Shopsystem konfiguriert.
        </MudAlert>
        <MudText Typo="Typo.body2">Bitte unter Einstellungen &gt; Shop einen Eintrag hinzufügen.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="GoToSettings">Zu den Einstellungen</MudButton>
        <MudButton Color="Color.Default" OnClick="Close">Schließen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Inject] NavigationManager Navigation { get; set; } = default!;

    private void GoToSettings()
    {
        MudDialog.Close();
        Navigation.NavigateTo("/settings");
    }

    private void Close() => MudDialog.Close();
}
